# =============================================================================
# Agentic AI Platform — environment template
# Copy to .env and fill in. NEVER commit .env.
# =============================================================================

# --- LLM Providers -----------------------------------------------------------
# Both providers are required for the full eval suite. OpenAI is the primary
# call path; Anthropic is the second-opinion provider.
OPENAI_API_KEY=replace-me-openai
ANTHROPIC_API_KEY=replace-me-anthropic

# --- Database (PostgreSQL + pgvector) ----------------------------------------
# Async DSN for the orchestrator (asyncpg driver). The Alembic migration tool
# uses the sync DSN; both resolve from the same env var via app.db.
DATABASE_URL=postgresql+asyncpg://agentic:agentic_dev@localhost:5432/agentic_platform
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis (task broker, working-memory cache) -------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Vector search ------------------------------------------------------------
VECTOR_DIM=1536
VECTOR_INDEX_TYPE=hnsw
VECTOR_EF_CONSTRUCTION=64
VECTOR_M=16

# --- Observability ------------------------------------------------------------
# Langfuse is optional; leaving blank disables it. Local dev uses the cloud
# host by default; switch to a self-hosted URL if running Langfuse in compose.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Auth / Governance --------------------------------------------------------
# JWT_SECRET MUST be at least 32 bytes in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-me-with-32-byte-random-secret-do-not-use-in-prod
JWT_ALGORITHM=HS256
AUDIT_LOG_RETENTION_DAYS=365

# --- API ----------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO
ENVIRONMENT=development
